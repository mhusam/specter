# Backend API port
API_PORT=4000

# PostgreSQL connection string
# For local development with Docker Compose: use the defaults below
# For production: use a strong password and restrict network access
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/specter

# Ollama — must be running locally before starting the server
# Pull your chosen model first: ollama pull gemma3:12b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b

# Directory for legacy file exports (Standard questionnaire flow)
CONTRACT_OUTPUT_DIR=./contracts

# Frontend → backend URL (Vite only reads VITE_* variables)
VITE_API_BASE_URL=http://localhost:4000
